{
  "name": "extraufla",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "better-auth": "1.6.9",
      "next-themes": "^0.4.6",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @extraufla/db db:push",
    "db:studio": "turbo -F @extraufla/db db:studio",
    "db:generate": "turbo -F @extraufla/db db:generate",
    "db:migrate": "turbo -F @extraufla/db db:migrate",
    "db:local": "turbo -F @extraufla/db db:local",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@extraufla/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@extraufla/config": "workspace:*",
    "@types/node": "catalog:",
    "cheerio": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  },
  "packageManager": "bun@1.3.13"
}
