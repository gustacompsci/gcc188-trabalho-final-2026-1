{
  "name": "@extraufla/db",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./schema/*": {
      "types": "./src/schema/*.ts",
      "default": "./src/schema/*.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "turso dev --db-file local.db",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@extraufla/env": "workspace:*",
    "@libsql/client": "0.15.15",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "libsql": "0.5.22",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@extraufla/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
